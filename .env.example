# ── Security ──────────────────────────────────────────────────────────────────
ADMIN_API_KEY=                         # Required in production (32+ hex chars). Generate: openssl rand -hex 32
ALLOWED_ORIGINS=http://localhost:5173  # Comma-separated allowed CORS origins

# ── Environment ───────────────────────────────────────────────────────────────
ENV=development                        # Set to "production" for prod deployment

# ── Season ────────────────────────────────────────────────────────────────────
CURRENT_SEASON=2026

# ── Scheduler ─────────────────────────────────────────────────────────────────
SCHEDULER_ENABLED=false                # Enable APScheduler weekly jobs (true in prod)

# ── Storage ───────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/f1ranker.db
DATA_DIR=./data
MODELS_DIR=./models

# ── Pipeline ──────────────────────────────────────────────────────────────────
PIPELINE_TIMEOUT_SECONDS=1800          # 30 min default for /api/refresh
